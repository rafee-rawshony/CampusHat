# =========================================================================
# CampusHat Backend — PRODUCTION Environment Variables
# =========================================================================
# On your VPS:
#   cp backend/.env.production.example backend/.env
#   nano backend/.env   ← fill in every value marked as CHANGE_THIS
#
# Then run:
#   docker-compose -f docker-compose.prod.yml up -d --build
# =========================================================================

# --- Django ---
DJANGO_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_50_CHARS_MINIMUM
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=178.128.122.157,24.144.83.255,campushat.com,www.campushat.com,localhost,127.0.0.1
ALLOWED_HOSTS=178.128.122.157,24.144.83.255,campushat.com,www.campushat.com,localhost,127.0.0.1
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD

# --- Database (PostgreSQL) ---
DB_NAME=campushat_db
DB_USER=campushat_user
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS (no trailing slash) ---
CORS_ALLOWED_ORIGINS=https://campushat.com,https://www.campushat.com,http://178.128.122.157,https://178.128.122.157,http://24.144.83.255,https://24.144.83.255

# --- CSRF (must include your domain so Django admin login works) ---
CSRF_TRUSTED_ORIGINS=https://campushat.com,https://www.campushat.com,http://178.128.122.157,https://178.128.122.157,http://24.144.83.255,https://24.144.83.255

# --- SSL / HTTPS mode ---
# SSL_MODE options:
#   flexible -> HTTP and HTTPS both work (no forced redirect, non-secure cookies)
#   strict   -> HTTPS-only (redirect + secure cookies + HSTS)
#   auto     -> derive from SITE_URL/FRONTEND_URL scheme
#
# Recommended for your current requirement (SSL + non-SSL both working): flexible
SSL_MODE=flexible
#
# Optional explicit overrides (normally leave unset):
# SECURE_SSL_REDIRECT=
# SESSION_COOKIE_SECURE=
# CSRF_COOKIE_SECURE=
# SECURE_HSTS_ENABLED=

# --- File Storage: AWS S3 OR DigitalOcean Spaces (pick one) ---
#
# Option A — DigitalOcean Spaces (recommended if deploying on DigitalOcean):
#   AWS_S3_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
#   AWS_ACCESS_KEY_ID=your-spaces-key
#   AWS_SECRET_ACCESS_KEY=your-spaces-secret
#   AWS_STORAGE_BUCKET_NAME=campushat-media
#   AWS_S3_REGION_NAME=sgp1
#   AWS_S3_CUSTOM_DOMAIN=campushat-media.sgp1.digitaloceanspaces.com
#
# Option B — AWS S3:
#   AWS_S3_ENDPOINT_URL=   (leave blank)
#   AWS_ACCESS_KEY_ID=your-aws-key
#   AWS_SECRET_ACCESS_KEY=your-aws-secret
#   AWS_STORAGE_BUCKET_NAME=campushat-media
#   AWS_S3_REGION_NAME=ap-southeast-1
#   AWS_S3_CUSTOM_DOMAIN=   (or your CloudFront domain)

AWS_S3_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=CHANGE_THIS
AWS_SECRET_ACCESS_KEY=CHANGE_THIS
AWS_STORAGE_BUCKET_NAME=campushat-media
AWS_S3_REGION_NAME=sgp1
AWS_S3_CUSTOM_DOMAIN=campushat-media.sgp1.digitaloceanspaces.com

# --- Email (Gmail App Password example) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=CHANGE_THIS_GMAIL_APP_PASSWORD
DEFAULT_FROM_EMAIL=CampusHat <noreply@yourdomain.com>
AUTO_VERIFY_EMAIL_ON_REGISTER=False

# --- Encryption (seller financial data) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_THIS_RUN_THE_COMMAND_ABOVE

# --- Site URLs ---
SITE_URL=https://campushat.com
FRONTEND_URL=https://campushat.com

# --- Google OAuth (Sign in with Google) ---
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized origins: https://yourdomain.com
GOOGLE_OAUTH_CLIENT_ID=CHANGE_THIS_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# --- Sentry (optional — error tracking) ---
SENTRY_DSN=

# --- Gunicorn / Celery workers ---
# Workers = (2 × CPU cores) + 1  → 2-core DigitalOcean droplet = 5 workers
GUNICORN_WORKERS=5
CELERY_CONCURRENCY=2
