docker exec campushat_backend python manage.py seed_universities# =========================================================================
# CampusHat Backend — PRODUCTION Environment Variables
# =========================================================================
# Copy this file to .env on your VPS and fill in ALL values.
# NEVER commit .env to git — it contains secrets.
# =========================================================================

# --- Django ---
DJANGO_SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING-50-CHARS-MINIMUM
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,YOUR_VPS_IP
DJANGO_SETTINGS_MODULE=config.settings.production

# --- Database (PostgreSQL) ---
DB_NAME=campushat_db
DB_USER=campushat_user
DB_PASSWORD=CHANGE-THIS-STRONG-DB-PASSWORD
DB_HOST=db
DB_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS ---
# Set this to your live frontend domain (NO trailing slash)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- AWS S3 (File storage — optional, falls back to local) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=campushat-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=

# --- Email (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@campushat.com
EMAIL_HOST_PASSWORD=CHANGE-THIS-APP-PASSWORD
DEFAULT_FROM_EMAIL=CampusHat <noreply@campushat.com>

# --- Sentry (Error tracking — optional) ---
SENTRY_DSN=

# --- Site URLs ---
SITE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# --- Gunicorn ---
# Workers = (2 × CPU cores) + 1  (e.g., 2-core VPS → 5)
GUNICORN_WORKERS=3
CELERY_CONCURRENCY=2
