# ===========================================
# CampusHat Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Django ---
DJANGO_SECRET_KEY=your-super-secret-key-change-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database (PostgreSQL) ---
DB_NAME=campushat_db
DB_USER=campushat_user
DB_PASSWORD=campushat_password
DB_HOST=db
DB_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- CSRF (Admin login behind Nginx) ---
# If you open admin via Nginx (e.g. http://localhost:8081/admin/), add that origin here.
CSRF_TRUSTED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# --- AWS S3 (Production file storage) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=campushat-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=

# --- Email ---
# DEV (default): leave EMAIL_HOST blank — Django will talk to the Mailpit
# container shipped with docker-compose. Inbox UI at http://localhost:8025/.
#
# PROD: pick a transactional email provider and fill in their SMTP creds:
#
#   Resend (recommended — modern, simple)
#     EMAIL_HOST=smtp.resend.com
#     EMAIL_PORT=465
#     EMAIL_USE_SSL=True
#     EMAIL_HOST_USER=resend
#     EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxx
#
#   AWS SES
#     EMAIL_HOST=email-smtp.<region>.amazonaws.com
#     EMAIL_PORT=587
#     EMAIL_USE_TLS=True
#     EMAIL_HOST_USER=<SES SMTP username>
#     EMAIL_HOST_PASSWORD=<SES SMTP password>
#
#   SendGrid / Mailgun / Postmark — see their docs for SMTP creds.
#
# Always set DEFAULT_FROM_EMAIL to a domain you control AND have DKIM/SPF
# configured for (otherwise Gmail/Outlook will reject your mail).
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CampusHat <noreply@campushat.local>

# DANGER: if True, every new registration is auto-marked as email-verified.
# Use ONLY for automated tests / CI. NEVER set True in production.
AUTO_VERIFY_EMAIL_ON_REGISTER=False

# --- Sentry (Production error tracking) ---
SENTRY_DSN=

# --- Site ---
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Google OAuth (Sign in with Google) ---
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 (and your production domain)
GOOGLE_OAUTH_CLIENT_ID=
