# =========================================================================
# CampusHat — Root-level docker-compose variables
# =========================================================================
# These are read by docker-compose.prod.yml for the FRONTEND build args.
# NEXT_PUBLIC_* values are baked into the JS bundle at build time.
#
# On your VPS:
#   cp .env.example .env
#   nano .env   ← fill in your domain
# =========================================================================

# Your live domain (no trailing slash).
# The frontend JS bundle will use this to call the API.
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1

# Same Google OAuth 2.0 Client ID as in backend/.env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_THIS_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
