# =========================================================================
# CampusHat — Root-level docker-compose variables
# =========================================================================
# These are read by docker-compose.prod.yml for service images, DB, and
# the FRONTEND build args. NEXT_PUBLIC_* values are baked into the JS
# bundle at build time.
#
# Local dev:    cp .env.example .env   ← defaults are fine
# Production:   cp .env.example .env   ← set DOCKER_REGISTRY + DB_PASSWORD
# =========================================================================

# --- Frontend build args ---
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_THIS_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# --- Database ---
DB_NAME=campushat_db
DB_USER=campushat_user
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# --- DigitalOcean Container Registry (DOCR) ---
# Local dev:  leave empty → images tagged as "campushat-backend:latest"
# Production: set your DOCR URL with trailing slash:
#   DOCKER_REGISTRY=registry.digitalocean.com/campushat/
#
# On VPS, just `docker compose pull` to get pre-built images from DOCR.
# Locally, `docker compose up --build` builds from source as usual.
DOCKER_REGISTRY=
IMAGE_TAG=latest
